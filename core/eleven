#!/bin/bash
# eleven — run a Work Louder SDK app on the host
#
# Usage: eleven run <app.py> [--geometry WxH] [--title "..."]
#
# Currently delegates to a pinned lv_micropython Unix build. Once the Swift
# shell lands, this CLI will call into the core library instead.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Path to the MicroPython binary built with LVGL + SDL support.
# Override with ELEVEN_MICROPYTHON env var.
: "${ELEVEN_MICROPYTHON:=/Users/malpern/local-code/worklouder/spikes/lvgl-mpy-macos/lv_micropython/ports/unix/build-lvgl/micropython}"

usage() {
    cat <<EOF
Usage:
  eleven run  <app.py>   [--geometry WxH] [--title "..."]
  eleven test <test.py>  [--geometry WxH] [--show]

Commands:
  run   Launch an app in an SDL window (interactive dev loop).
  test  Run an automated test script headlessly. With --show, keep the
        SDL window visible so you can watch the test drive the app.

Options:
  --geometry WxH   display size in pixels (default 170x320)
  --title TITLE    window title (default: filename)
  --show           test: keep the window visible during the run

Env vars:
  ELEVEN_MICROPYTHON  path to micropython binary (default: built locally)
EOF
}

cmd="${1:-}"
case "$cmd" in
    run|test)
        SUBCMD="$cmd"
        shift
        ;;
    -h|--help|help|"")
        usage
        exit 0
        ;;
    *)
        echo "eleven: unknown command '$cmd'" >&2
        usage
        exit 1
        ;;
esac

SCRIPT_ARG="${1:-}"
if [[ -z "$SCRIPT_ARG" ]]; then
    echo "eleven: missing file" >&2
    usage
    exit 1
fi
if [[ ! -f "$SCRIPT_ARG" ]]; then
    echo "eleven: $SCRIPT_ARG not found" >&2
    exit 1
fi
shift

GEOMETRY="170x320"
TITLE="$(basename "$SCRIPT_ARG" .py)"
SHOW=""
while (($#)); do
    case "$1" in
        --geometry) GEOMETRY="$2"; shift 2 ;;
        --title)    TITLE="$2";    shift 2 ;;
        --show)     SHOW="1";      shift ;;
        *) echo "eleven: unknown option '$1'" >&2; usage; exit 1 ;;
    esac
done

if [[ ! -x "$ELEVEN_MICROPYTHON" ]]; then
    echo "eleven: micropython binary not found at $ELEVEN_MICROPYTHON" >&2
    echo "        build it first or set ELEVEN_MICROPYTHON" >&2
    exit 1
fi

ABS_PATH="$(cd "$(dirname "$SCRIPT_ARG")" && pwd)/$(basename "$SCRIPT_ARG")"
export ELEVEN_GEOMETRY="$GEOMETRY"
export ELEVEN_TITLE="$TITLE"
export ELEVEN_CORE_DIR="$REPO_ROOT/core"
export ELEVEN_REPO_ROOT="$REPO_ROOT"
export ELEVEN_PLATFORM="${ELEVEN_PLATFORM:-nomad-v1}"

if [[ "$SUBCMD" == "run" ]]; then
    export ELEVEN_APP_PATH="$ABS_PATH"
    exec "$ELEVEN_MICROPYTHON" "$REPO_ROOT/core/host.py"
else
    export ELEVEN_TEST_SCRIPT="$ABS_PATH"
    [[ -n "$SHOW" ]] && export ELEVEN_TEST_SHOW=1
    exec "$ELEVEN_MICROPYTHON" "$REPO_ROOT/core/test_host.py"
fi
